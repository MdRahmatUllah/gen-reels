ENVIRONMENT=development
APP_NAME=Reels Generation Backend
APP_BASE_URL=http://localhost:8000
FRONTEND_BASE_URL=http://localhost:5173
DATABASE_URL=postgresql+psycopg://reels:reels@localhost:5432/reels
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
CELERY_TASK_ALWAYS_EAGER=false
MINIO_ENDPOINT=localhost:9000
# When running inside Docker the endpoint is minio:9000 (internal); set this
# to the browser-reachable host so presigned download URLs work in the UI.
MINIO_PUBLIC_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_SECURE=false
MINIO_REGION=us-east-1
MINIO_BUCKET_ASSETS=reels-assets
MINIO_BUCKET_QUARANTINE=reels-quarantine
MINIO_BUCKET_TEMP=reels-temp
MINIO_BUCKET_MODELS=reels-models
LOCAL_STORAGE_ROOT=.local-storage
APP_ENCRYPTION_KEY=
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=
JWT_ACCESS_TOKEN_TTL_MINUTES=15
JWT_REFRESH_TOKEN_TTL_DAYS=180
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_VERSION=2024-10-21
AZURE_OPENAI_CHAT_DEPLOYMENT=
# Seconds for chat/completions (scene plan + prompt pairs need more than brief/ideas).
AZURE_OPENAI_CHAT_TIMEOUT_SECONDS=300
AZURE_OPENAI_IMAGE_DEPLOYMENT=
AZURE_OPENAI_IMAGE_MODEL=gpt-image-1.5
AZURE_OPENAI_IMAGE_API_VERSION=2024-02-01
AZURE_OPENAI_SPEECH_DEPLOYMENT=
AZURE_OPENAI_SPEECH_MODEL=tts-1-hd
AZURE_OPENAI_SPEECH_API_VERSION=2025-04-01-preview
AZURE_OPENAI_SPEECH_VOICE=alloy
AZURE_CONTENT_SAFETY_ENDPOINT=
AZURE_CONTENT_SAFETY_API_KEY=
AZURE_CONTENT_SAFETY_API_VERSION=2024-09-15-preview
AZURE_CONTENT_SAFETY_BLOCK_THRESHOLD=4
VERTEX_AI_PROJECT_ID=
VERTEX_AI_LOCATION=us-central1
VERTEX_AI_MODEL_ID=veo-3.1-generate-001
VERTEX_AI_ACCESS_TOKEN=
VERTEX_AI_OUTPUT_STORAGE_URI=
MAIL_FROM=noreply@reels.local
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
PASSWORD_RESET_TTL_MINUTES=60
IDEMPOTENCY_RETENTION_HOURS=24
PLANNING_JOB_TIMEOUT_MINUTES=30
RENDER_JOB_TIMEOUT_MINUTES=120
LOCAL_WORKER_HEARTBEAT_TIMEOUT_SECONDS=180
RENDER_EVENT_STREAM_HEARTBEAT_SECONDS=15
WEBHOOK_MAX_ATTEMPTS=5
WEBHOOK_RETRY_BASE_SECONDS=30
EXPORT_MODERATION_SAMPLE_RATE=0.10
EXPORT_MODERATION_LOOKBACK_DAYS=30
FFMPEG_BIN=ffmpeg
FFPROBE_BIN=ffprobe
FFMPEG_DOCKER_IMAGE=jrottenberg/ffmpeg:6.1-alpine
ALLOW_EXPORT_WITHOUT_MUSIC=true
USE_STUB_PROVIDERS=false
